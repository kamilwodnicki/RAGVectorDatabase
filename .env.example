# Skopiuj ten plik do .env i dostosuj wartości.
# Wszystkie zmienne mają sensowne defaulty — ustaw tylko te, które chcesz zmienić.

# =========================================================================
# Build — wariant CUDA (wybierz jedno)
# =========================================================================
#   cu118  → GTX 1060, RTX 2080, RTX 3090  (CUDA 11.8, sterownik >= 520)
#   cu126  → RTX 4090, RTX 5080, RTX 5090  (CUDA 12.6, sterownik >= 560)
#   cpu    → brak GPU / CI
CUDA_VARIANT=cu118

# =========================================================================
# Wariant bazy (BASE_TAG) — przełącznik między bazami
# =========================================================================
# Każdy BASE_TAG ma własną kolekcję w Qdrant ('documents_<tag>') i własną bazę
# w MongoDB ('rag_<tag>'). Zmiana modelu / EMBEDDING_DIM / chunkingu = nowy
# BASE_TAG = nowa baza, bez nadpisywania poprzedniej. Bazy koegzystują;
# switch = edycja .env + 'docker compose up -d --force-recreate rag-server'.
#
# Lista wariantów: 'docker compose exec rag-server python manage.py db variants'
# Usunięcie:       'docker compose exec rag-server python manage.py db drop <tag>'
BASE_TAG=default

# Model embeddingowy. Każdy ma swój wymiar wektora (EMBEDDING_DIM) i styl
# promptów (EMBEDDING_PROMPT_STYLE).
#
#   Rodzina E5 (style=e5):
#     intfloat/multilingual-e5-small   → dim 384
#     intfloat/multilingual-e5-base    → dim 768  (default)
#     intfloat/multilingual-e5-large   → dim 1024
#
#   Rodzina Qwen3-Embedding (style=qwen3, większe modele LLM-bazowane):
#     Qwen/Qwen3-Embedding-0.6B        → dim 1024
#     Qwen/Qwen3-Embedding-4B          → dim 2560
#     Qwen/Qwen3-Embedding-8B          → dim 4096
#
#   Pozostałe (style=none):
#     BAAI/bge-m3                       → dim 1024
#     sdadas/mmlw-roberta-large         → dim 1024  (specjalizowany pod polski)
MODEL_NAME=intfloat/multilingual-e5-base
EMBEDDING_DIM=768

# Styl promptów embedderów. MUSI pasować do MODEL_NAME — niewłaściwy styl
# pogarsza jakość retrieval o kilkadziesiąt %.
#   e5     — prefix "passage:"/"query:" (rodzina intfloat/e5*)
#   qwen3  — instruction-tuned (Qwen/Qwen3-Embedding*)
#   none   — surowy tekst (BGE-M3, MMLW, większość pozostałych)
EMBEDDING_PROMPT_STYLE=e5

# Instrukcja dla style=qwen3 (ignorowana dla pozostałych). Domyślna jest
# uniwersalna; możesz przestawić per-domena jeśli eksperymentujesz.
# QWEN3_INSTRUCTION=Given a search query, retrieve relevant Polish news articles

# Etykieta eksperymentu (sesji testowej). Trafia do logów /query/ — w Grafanie
# i Loki możesz filtrować po niej, żeby porównywać "ten sam BASE_TAG, różne k/filtry".
# Pusty string = brak etykiety.
EXPERIMENT_ID=

# =========================================================================
# Ekstrakcja dokumentów
# =========================================================================
# Strategia parsowania PDF:
#   fast    — szybka, tekstowe PDF-y (domyślna)
#   hi_res  — OCR + layout, skany i złożone układy (wymaga poppler)
EXTRACTION_STRATEGY=fast

# Języki dla unstructured (lista po przecinku, ISO 639-2/3).
EXTRACTION_LANGUAGES=pol,eng

# =========================================================================
# Chunking — parenty (duże fragmenty przechowywane w MongoDB)
# =========================================================================
# Twardy limit długości parenta w znakach. Parent nigdy go nie przekroczy.
PARENT_MAX_SIZE=2000

# Miękki limit — po przekroczeniu chunker zamyka parent na najbliższej granicy
# elementu. Trzymaj poniżej PARENT_MAX_SIZE (~75%).
PARENT_SOFT_SIZE=1500

# Sekcje krótsze niż ta wartość są scalane z sąsiadami (unika mini-parentów).
PARENT_COMBINE_UNDER=800

# Overlap między kolejnymi parentami w znakach. 0 = brak overlapu.
PARENT_OVERLAP=0

# =========================================================================
# Chunking — childy (małe fragmenty embedowane w Qdrant)
# =========================================================================
# Rozmiar childa w znakach. Mniejsze = precyzyjniejszy retrieval, więcej wektorów.
# Typowe wartości: 300–600.
CHILD_CHUNK_SIZE=400

# Overlap między sąsiadującymi childami w obrębie parenta.
# Typowo 15–25% CHILD_CHUNK_SIZE.
CHILD_CHUNK_OVERLAP=80

# =========================================================================
# Retrieval
# =========================================================================
# Domyślna liczba childów pobieranych z Qdrant (gdy klient nie poda k).
# Większe = lepsza pokrywalność, więcej parentów zwracanych z MongoDB.
DEFAULT_K=3

# Rozmiar batcha przy upsercie do Qdrant. Qdrant odrzuca requesty > 32 MB —
# batching zapobiega błędom "Payload error: JSON payload ... is larger than ...".
# Zmniejsz jeśli nadal widzisz błąd (bardzo długie teksty), zwiększ dla szybszego
# ingestu gdy dokumenty są krótkie.
QDRANT_UPSERT_BATCH_SIZE=256

# Tryb wyszukiwania:
#   dense   — tylko wektory semantyczne (E5). Dobre dla parafraz i synonimów.
#   sparse  — tylko BM25. Dobre dla rzadkich terminów (akronimy, kody, nazwy własne).
#   hybrid  — oba + weighted Reciprocal Rank Fusion. Najlepsze w większości przypadków.
RETRIEVAL_MODE=hybrid

# =========================================================================
# Hybrid search — tuning (używane gdy RETRIEVAL_MODE=hybrid)
# =========================================================================
# Wagi w formule RRF:  score = w_dense/(k+rank_d) + w_sparse/(k+rank_s)
# Zwiększ HYBRID_SPARSE_WEIGHT gdy korpus ma dużo akronimów/kodów technicznych.
# Zwiększ HYBRID_DENSE_WEIGHT gdy zapytania są konwersacyjne (parafrazy).
HYBRID_DENSE_WEIGHT=1.0
HYBRID_SPARSE_WEIGHT=1.0

# Stała RRF — tłumi wpływ dokumentów z niskich pozycji rankingu.
# Typowa wartość 60; rzadko się zmienia.
HYBRID_RRF_K=60

# Model sparse embeddings (fastembed).
# "Qdrant/bm25" — klasyczny BM25 z generycznym IDF (domyślny).
SPARSE_MODEL_NAME=Qdrant/bm25

# =========================================================================
# Reranker (opcjonalny krok po retrievalu)
# =========================================================================
# Cross-encoder ocenia pary (query, parent_text) i przeszereguje top kandydatów
# z retrievalu. Mocno poprawia precyzję top-k (filtruje "listingi" i wzmianki
# pozbawione kontekstu merytorycznego). Koszt: +50-500 ms latency per zapytanie
# zależnie od device i RERANKER_RETRIEVE_K.
#
# Workflow: retrieve K=RERANKER_RETRIEVE_K kandydatów → dedupe do parentów →
# fetch tekstów z Mongo → reranker przeszereguje → zwracamy top request.k.
RERANKER_ENABLED=false

# Multilingual cross-encoder z dobrym wsparciem polskiego.
# Alternatywy: Alibaba-NLP/gte-multilingual-reranker-base (lżejsza).
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# cpu — bezpieczny default, +300-500 ms latency dla 20 par.
# cuda — wymaga GPU dla API, +30-50 ms latency. UWAGA: jeśli ingest też używa
# GPU, mogą konkurować — sprawdź czy API_DEVICE/INGEST_DEVICE się nie biją.
RERANKER_DEVICE=cpu

# Ile children pobrać z retrievala przed dedupem do parentów i rerankowaniem.
# Większe → lepsza precyzja po rerankingu, wolniej. Typowo 20-50.
RERANKER_RETRIEVE_K=20

# Limit znaków parenta przekazywanych do rerankera. bge-reranker-v2-m3 ma
# max_length 512 tokenów ≈ 1500-2000 znaków polskich. Większe = ucięcie.
RERANKER_MAX_PARENT_CHARS=2000

# =========================================================================
# Logowanie
# =========================================================================
# Logi lecą równolegle do pliku (./logs/app.log na hoście, przeżywa restart kontenera)
# i na stdout (docker logs / make logs).
#
# Poziomy: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Katalog logów wewnątrz kontenera. Mapowany na ./logs na hoście (docker-compose).
LOG_DIR=/app/logs

# Rotacja: codzienna o północy. Bieżący plik to app.log, archiwa: app.log.YYYY-MM-DD.
# Logi NIE są automatycznie kasowane — żyją tak długo jak release katalog
# (deploy.yml usuwa releases starsze niż KEEP_RELEASES, razem z ich logami).

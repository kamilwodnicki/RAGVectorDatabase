{
  "uid": "containers",
  "title": "Containers",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {"from": "now-1h", "to": "now"},
  "timezone": "browser",
  "tags": ["rag", "containers"],
  "templating": {
    "list": [
      {
        "name": "container",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "query": "label_values(container_last_seen{name!=\"\"}, name)",
        "refresh": 1,
        "includeAll": true,
        "multi": true,
        "current": {"selected": true, "text": "All", "value": "$__all"}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "CPU per container (cores)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "avg by (name) (rate(container_cpu_usage_seconds_total{name=~\"$container\"}[1m]))",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "none", "min": 0}}
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "RAM per container (working set)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "max by (name) (container_memory_working_set_bytes{name=~\"$container\"})",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "bytes", "min": 0}}
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Disk write per container",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "avg by (name) (rate(container_fs_writes_bytes_total{name=~\"$container\"}[1m]))",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "Bps", "min": 0}}
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Disk read per container",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "avg by (name) (rate(container_fs_reads_bytes_total{name=~\"$container\"}[1m]))",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "Bps", "min": 0}}
    },
    {
      "id": 5,
      "type": "table",
      "title": "Container status",
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 16},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "time() - max by (name) (container_start_time_seconds{name=~\"$container\"})",
          "legendFormat": "{{name}}",
          "refId": "A",
          "instant": true,
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "s"},
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "Value"},
            "properties": [
              {"id": "displayName", "value": "Uptime"},
              {"id": "custom.cellOptions", "value": {"type": "color-text"}}
            ]
          }
        ]
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {"Time": true, "__name__": true, "id": true, "image": true, "instance": true, "job": true},
            "indexByName": {"name": 0, "Value": 1}
          }
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "OOM events per container (cumulative)",
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 16},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "max by (name) (container_oom_events_total{name=~\"$container\"})",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 1}
            ]
          }
        }
      }
    }
  ]
}

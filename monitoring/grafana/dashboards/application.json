{
  "uid": "application",
  "title": "Application",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {"from": "now-1h", "to": "now"},
  "timezone": "browser",
  "tags": ["rag", "application"],
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "/query/ — latency p50 / p95 / p99",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(http_request_duration_seconds_bucket{endpoint=\"/query/\"}[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{endpoint=\"/query/\"}[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket{endpoint=\"/query/\"}[5m])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s", "min": 0}}
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "/query/ — request rate by status",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum by (status) (rate(http_request_duration_seconds_count{endpoint=\"/query/\"}[1m]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "reqps", "min": 0}}
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Qdrant client — latency p50 / p95 / p99",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(qdrant_query_duration_seconds_bucket[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(qdrant_query_duration_seconds_bucket[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(qdrant_query_duration_seconds_bucket[5m])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s", "min": 0}}
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Mongo client — latency p50 / p95 / p99",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(mongo_query_duration_seconds_bucket[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(mongo_query_duration_seconds_bucket[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(mongo_query_duration_seconds_bucket[5m])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s", "min": 0}}
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "/query/ — average duration",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "rate(http_request_duration_seconds_sum{endpoint=\"/query/\"}[5m]) / rate(http_request_duration_seconds_count{endpoint=\"/query/\"}[5m])",
          "legendFormat": "avg",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s", "min": 0}}
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Latency breakdown — total vs Qdrant vs Mongo (p95)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{endpoint=\"/query/\"}[5m])))",
          "legendFormat": "/query/ total",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(qdrant_query_duration_seconds_bucket[5m])))",
          "legendFormat": "Qdrant",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(mongo_query_duration_seconds_bucket[5m])))",
          "legendFormat": "Mongo",
          "refId": "C"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s", "min": 0}}
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Total /query/ requests",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 24},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(http_request_duration_seconds_count{endpoint=\"/query/\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "none"}}
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Error rate (5xx) — last 5m",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 24},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "100 * sum(rate(http_request_duration_seconds_count{endpoint=\"/query/\",status=~\"5..\"}[5m])) / sum(rate(http_request_duration_seconds_count{endpoint=\"/query/\"}[5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 1},
              {"color": "red", "value": 5}
            ]
          }
        }
      }
    },
    {
      "id": 9,
      "type": "stat",
      "title": "Throughput (req/s) — last 5m",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 24},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(rate(http_request_duration_seconds_count{endpoint=\"/query/\"}[5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "reqps"}}
    },
    {
      "id": 10,
      "type": "stat",
      "title": "Avg /query/ duration — last 5m",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 24},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(rate(http_request_duration_seconds_sum{endpoint=\"/query/\"}[5m])) / sum(rate(http_request_duration_seconds_count{endpoint=\"/query/\"}[5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    }
  ]
}

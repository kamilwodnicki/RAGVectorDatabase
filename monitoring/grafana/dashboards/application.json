{
  "uid": "application",
  "title": "Application",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {"from": "now-1h", "to": "now"},
  "timezone": "browser",
  "tags": ["rag", "application"],
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "/query/ — latency p50 / p95 / p99",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(http_request_duration_seconds_bucket{endpoint=\"/query/\"}[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{endpoint=\"/query/\"}[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket{endpoint=\"/query/\"}[5m])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s", "min": 0}}
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "/query/ — request rate by status",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum by (status) (rate(http_request_duration_seconds_count{endpoint=\"/query/\"}[1m]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "reqps", "min": 0}}
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Qdrant client — latency p50 / p95 / p99",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(qdrant_query_duration_seconds_bucket[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(qdrant_query_duration_seconds_bucket[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(qdrant_query_duration_seconds_bucket[5m])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s", "min": 0}}
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Mongo client — latency p50 / p95 / p99",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(mongo_query_duration_seconds_bucket[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(mongo_query_duration_seconds_bucket[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(mongo_query_duration_seconds_bucket[5m])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s", "min": 0}}
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "/query/ — average duration",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "rate(http_request_duration_seconds_sum{endpoint=\"/query/\"}[5m]) / rate(http_request_duration_seconds_count{endpoint=\"/query/\"}[5m])",
          "legendFormat": "avg",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s", "min": 0}}
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Latency breakdown — total vs Qdrant vs Mongo (p95)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{endpoint=\"/query/\"}[5m])))",
          "legendFormat": "/query/ total",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(qdrant_query_duration_seconds_bucket[5m])))",
          "legendFormat": "Qdrant",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(mongo_query_duration_seconds_bucket[5m])))",
          "legendFormat": "Mongo",
          "refId": "C"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s", "min": 0}}
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Total /query/ requests",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 24},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(http_request_duration_seconds_count{endpoint=\"/query/\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "none"}}
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Error rate (5xx) — last 5m",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 24},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "100 * sum(rate(http_request_duration_seconds_count{endpoint=\"/query/\",status=~\"5..\"}[5m])) / sum(rate(http_request_duration_seconds_count{endpoint=\"/query/\"}[5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 1},
              {"color": "red", "value": 5}
            ]
          }
        }
      }
    },
    {
      "id": 9,
      "type": "stat",
      "title": "Throughput (req/s) — last 5m",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 24},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(rate(http_request_duration_seconds_count{endpoint=\"/query/\"}[5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "reqps"}}
    },
    {
      "id": 10,
      "type": "stat",
      "title": "Avg /query/ duration — last 5m",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 24},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(rate(http_request_duration_seconds_sum{endpoint=\"/query/\"}[5m])) / sum(rate(http_request_duration_seconds_count{endpoint=\"/query/\"}[5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Children returned per query (rate)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 28},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, mode) (rate(qdrant_children_per_query_bucket[5m])))",
          "legendFormat": "p50 {{mode}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, mode) (rate(qdrant_children_per_query_bucket[5m])))",
          "legendFormat": "p95 {{mode}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "none", "min": 0}}
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Top score (p50 / p95) per mode",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 28},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, mode) (rate(qdrant_top_score_bucket[5m])))",
          "legendFormat": "p50 {{mode}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, mode) (rate(qdrant_top_score_bucket[5m])))",
          "legendFormat": "p95 {{mode}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "none", "min": 0, "max": 1}}
    },
    {
      "id": 13,
      "type": "stat",
      "title": "Empty result rate (last 5m)",
      "gridPos": {"h": 4, "w": 12, "x": 0, "y": 36},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "100 * sum(rate(query_parents_returned_bucket{le=\"0.0\"}[5m])) / sum(rate(query_parents_returned_count[5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 5},
              {"color": "red", "value": 20}
            ]
          }
        }
      }
    },
    {
      "id": 14,
      "type": "stat",
      "title": "Total queries (cumulative)",
      "gridPos": {"h": 4, "w": 12, "x": 12, "y": 36},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(qdrant_children_per_query_count)",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "none"}}
    },
    {
      "id": 15,
      "type": "logs",
      "title": "Query log — kompaktowy stream (klik = pełen JSON)",
      "gridPos": {"h": 14, "w": 24, "x": 0, "y": 40},
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [
        {
          "expr": "{container=\"rag-server\", event=\"query\"} | json | json children=\"children\", parents=\"returned_parent_ids\" | line_format \"QUERY: {{.query}} | mode={{.mode}} | top={{.top_score}} | n_parents={{.n_parents}} | exp={{.experiment_id}} | {{.duration_ms}}ms\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "wrapLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    }
  ]
}

{
  "uid": "gpu",
  "title": "GPU",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {"from": "now-1h", "to": "now"},
  "timezone": "browser",
  "tags": ["rag", "gpu"],
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "GPU utilization (%)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "DCGM_FI_DEV_GPU_UTIL",
          "legendFormat": "GPU {{gpu}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100}}
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "VRAM used (MiB)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "DCGM_FI_DEV_FB_USED",
          "legendFormat": "used GPU {{gpu}}",
          "refId": "A"
        },
        {
          "expr": "DCGM_FI_DEV_FB_FREE",
          "legendFormat": "free GPU {{gpu}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "mbytes", "min": 0}}
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "GPU temperature (°C)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "DCGM_FI_DEV_GPU_TEMP",
          "legendFormat": "GPU {{gpu}} core",
          "refId": "A"
        },
        {
          "expr": "DCGM_FI_DEV_MEMORY_TEMP",
          "legendFormat": "GPU {{gpu}} memory",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 75},
              {"color": "red", "value": 83}
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Power usage (W)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "DCGM_FI_DEV_POWER_USAGE",
          "legendFormat": "GPU {{gpu}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 300},
              {"color": "red", "value": 350}
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Memory bandwidth utilization (%)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "DCGM_FI_DEV_MEM_COPY_UTIL",
          "legendFormat": "GPU {{gpu}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100}}
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Clocks (MHz)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "DCGM_FI_DEV_SM_CLOCK",
          "legendFormat": "SM clock GPU {{gpu}}",
          "refId": "A"
        },
        {
          "expr": "DCGM_FI_DEV_MEM_CLOCK",
          "legendFormat": "Memory clock GPU {{gpu}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "rotmhz"}}
    }
  ]
}
